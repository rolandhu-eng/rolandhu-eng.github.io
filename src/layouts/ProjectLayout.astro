---
import Layout from './Layout.astro';
import SubpageNav from '../components/SubpageNav.astro';


interface TocItem {
  id: string;
  label: string;
}

interface SubpageItem {
  id: string;
  label: string;
  href: string;
  children?: SubpageItem[];
}

interface Props {
  title: string;
  description: string;
  dateRange: string;
  tags: string[];
  heroMedia: string;
  isVideo?: boolean;
  /** Vertical object alignment for hero backgrounds */
  heroPosition?: string;
  toc: TocItem[];
  /** If provided, renders multi-page navigation with nested TOC under the active page */
  subpages?: SubpageItem[];
  /** Required when subpages are provided — identifies the current page */
  activePageId?: string;
  /** Set to false to hide the hero banner (used for non-overview subpages) */
  showHero?: boolean;
  /** Label shown above navigation sidebar (defaults to "On This Page") */
  sidebarTitle?: string;
  /** Project name shown in subpage header breadcrumb when hero is hidden */
  projectName?: string;
  /** Custom label above the hero title (defaults to "Project Documentation") */
  statusLabel?: string;
  /** If true, shows an animated green dot next to the status label */
  statusDot?: boolean;
}

const { 
  title, 
  description, 
  dateRange, 
  tags, 
  heroMedia, 
  isVideo = false, 
  heroPosition = 'center',
  toc,
  subpages,
  activePageId,
  showHero = true,
  sidebarTitle = "On This Page",
  projectName,
  statusLabel = "Project Documentation",
  statusDot = false
} = Astro.props;

const hasSubpages = subpages && subpages.length > 0;

// Build a flattened ordered list of pages (top-level then children) to compute linear prev/next
const flattenPages = () => {
  if (!subpages) return [];
  const list: Array<{ id: string; label: string; href: string }> = [];
  subpages.forEach((p) => {
    list.push({ id: p.id, label: p.label, href: p.href });
    if (p.children) {
      p.children.forEach((c) => list.push({ id: c.id, label: c.label, href: c.href }));
    }
  });
  return list;
};

const flatPages = flattenPages();
const currentIndex = flatPages.findIndex((p) => p.id === activePageId);
const prevPage = currentIndex > 0 ? flatPages[currentIndex - 1] : undefined;
const nextPage = (currentIndex !== -1 && currentIndex < flatPages.length - 1) ? flatPages[currentIndex + 1] : undefined;
---

<Layout title={`${title} | Roland Hu`} description={`${title} Project - Roland Hu`}>
  <!-- HERO -->
  {showHero && (
    <section class="relative w-full h-[50vh] min-h-[400px] flex items-center overflow-hidden border-b border-slate-200 dark:border-slate-800">
      {isVideo ? (
        <video class={`absolute inset-0 w-full h-full object-cover object-${heroPosition}`} autoplay loop muted playsinline>
          <source src={heroMedia} type="video/mp4" />
        </video>
      ) : (
        <img src={heroMedia} alt={`${title} project`} class={`absolute inset-0 w-full h-full object-cover object-${heroPosition}`} />
      )}

      <div class="absolute inset-0 bg-slate-950/50 dark:bg-slate-950/60 z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-900/50 to-transparent z-10"></div>

      <div class="relative z-20 max-w-5xl w-full mx-auto px-4 py-12 flex flex-col justify-end h-full">
        <a class="font-mono text-xs text-blue-200 hover:text-white dark:text-blue-300 dark:hover:text-white no-underline mb-6 inline-block" href="/projects">
          ← Back to Projects
        </a>
        <p class="flex items-center gap-2 font-mono text-xs text-slate-100 dark:text-slate-200 tracking-widest uppercase mb-2">
          {statusDot && (
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
          )}
          {statusLabel}
        </p>
        <h1 class="text-4xl md:text-5xl font-semibold text-white dark:text-white tracking-tight leading-none mb-3 drop-shadow-[0_2px_8px_rgba(0,0,0,0.7)]">
          {title}
        </h1>
        <p class="text-base text-slate-100 dark:text-slate-200 max-w-xl leading-relaxed mb-6 font-light drop-shadow-[0_1px_4px_rgba(0,0,0,0.7)]">
          {description}
        </p>
        <div class="flex flex-wrap gap-1.5 font-mono text-[10px]">
          <span class="px-2 py-0.5 rounded border border-white/20 bg-slate-900/80 text-white shadow-sm backdrop-blur-sm">
            {dateRange}
          </span>
          {tags.map((tag) => (
            <span class="px-2 py-0.5 rounded border border-white/20 bg-white/15 text-slate-100 shadow-sm backdrop-blur-sm">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- MAIN SECTION -->
  <main class={`max-w-screen-2xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow lg:grid lg:grid-cols-[200px_minmax(0,1fr)_200px] lg:gap-12 items-start ${!showHero ? 'mt-6' : ''}`}>
    
    <!-- Left Sidebar -->
    <aside class="hidden lg:block sticky top-28 self-start">
      <p class="font-mono text-[12px] font-semibold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-3 pl-3">
        {sidebarTitle}
      </p>

      {hasSubpages ? (
        <SubpageNav items={subpages!} activePageId={activePageId} toc={toc} />
      ) : (
        <nav class="relative flex flex-col">
          <div class="absolute left-0 top-0 bottom-0 w-px bg-slate-200 dark:bg-slate-700" />
          {toc.map((item) => (
            <a
              href={`#${item.id}`}
              class="toc-link group relative -ml-px pl-3 py-1.5 font-mono text-[12px] leading-snug border-l-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-600 transition-all duration-150 block"
              data-active-classes="text-blue-600 dark:text-blue-400 border-blue-500 dark:border-blue-400 font-medium"
              data-inactive-classes="text-slate-500 dark:text-slate-400 border-transparent hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-600"
            >
              {item.label}
            </a>
          ))}
        </nav>
      )}
    </aside>

    <!-- Center Column: Content -->
    <div class="min-w-0 max-w-5xl mx-auto w-full flex flex-col gap-14">
      {/* Subpage header when hero is hidden */}
      {!showHero && projectName && (
        <div class="border-b border-slate-200 dark:border-slate-800 pb-4">
          <p class="font-mono text-[10px] text-blue-600 dark:text-blue-500 uppercase tracking-widest mb-1">{projectName}</p>
          <h1 class="text-3xl font-semibold text-slate-900 dark:text-white tracking-tight">
            {title}
          </h1>
        </div>
      )}

      <slot />

      <div class="pt-8 border-t border-slate-200 dark:border-slate-800 space-y-6">
        {hasSubpages && (prevPage || nextPage) && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {prevPage ? (
              <a 
                href={prevPage.href} 
                class="flex flex-col p-4 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-slate-400 dark:hover:border-slate-600 bg-white dark:bg-slate-900/40 transition-colors no-underline group"
              >
                <span class="font-mono text-[10px] uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  ← Previous
                </span>
                <span class="text-sm font-medium text-slate-900 dark:text-white">
                  {prevPage.label}
                </span>
              </a>
            ) : <div class="hidden sm:block"></div>}

            {nextPage && (
              <a 
                href={nextPage.href} 
                class="flex flex-col p-4 rounded-lg border border-slate-200 dark:border-slate-800 hover:border-slate-400 dark:hover:border-slate-600 bg-white dark:bg-slate-900/40 transition-colors no-underline text-right group sm:col-start-2"
              >
                <span class="font-mono text-[10px] uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  Next →
                </span>
                <span class="text-sm font-medium text-slate-900 dark:text-white">
                  {nextPage.label}
                </span>
              </a>
            )}
          </div>
        )}

        <div>
          <a class="font-mono text-xs text-blue-600 dark:text-blue-500 hover:text-blue-800 dark:hover:text-blue-300 no-underline inline-block" href="/projects">
            ← Return to Projects
          </a>
        </div>
      </div>
    </div>

    <div class="hidden lg:block"></div>
  </main>
  
<script>
document.addEventListener('DOMContentLoaded', () => {
  // Only select real TOC-linked sections — exclude wrapper elements like the
  // markdown container itself, which was matching the selector but has no
  // corresponding .toc-link.
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const validIds = new Set(
    Array.from(tocLinks).map(l => l.getAttribute('href')?.substring(1)).filter(Boolean)
  );

  const targets = Array.from(
    document.querySelectorAll<HTMLElement>('main section[id], .prose h1[id]')
  ).filter(t => validIds.has(t.id));

  if (!tocLinks.length || !targets.length) return;

  let isClickScrolling = false;
  let clickScrollTimeout: ReturnType<typeof setTimeout>;

  const setActiveLink = (targetId: string) => {
    tocLinks.forEach(link => {
      const isTarget = link.getAttribute('href') === `#${targetId}`;
      const activeClasses   = (link.dataset.activeClasses   ?? '').split(' ').filter(Boolean);
      const inactiveClasses = (link.dataset.inactiveClasses ?? '').split(' ').filter(Boolean);

      if (isTarget) {
        link.classList.remove(...inactiveClasses);
        link.classList.add(...activeClasses);
      } else {
        link.classList.remove(...activeClasses);
        link.classList.add(...inactiveClasses);
      }
    });
  };

  tocLinks.forEach(link => {
    link.addEventListener('click', () => {
      const href = link.getAttribute('href');
      if (!href) return;
      setActiveLink(href.substring(1));
      isClickScrolling = true;
      clearTimeout(clickScrollTimeout);
      clickScrollTimeout = setTimeout(() => { isClickScrolling = false; }, 800);
    });
  });

  const observer = new IntersectionObserver((entries) => {
    if (isClickScrolling) return;
    const intersectingEntry = entries.find(e => e.isIntersecting);
    if (intersectingEntry) {
      const id = intersectingEntry.target.getAttribute('id');
      if (id) setActiveLink(id);
    }
  }, { root: null, rootMargin: '-20% 0px -60% 0px', threshold: 0 });

  targets.forEach(t => observer.observe(t));

  // Default: if nothing is intersecting yet (e.g. page loaded at the very
  // top, before any section has scrolled into the active zone), fall back
  // to whichever target is closest to — or above — the top of the viewport.
  // If none have been scrolled to at all, default to the first target.
  const setInitialActiveLink = () => {
    let currentId: string | null = null;

    for (const t of targets) {
      const rect = t.getBoundingClientRect();
      if (rect.top <= window.innerHeight * 0.20) {
        currentId = t.id;
      }
    }

    if (!currentId) currentId = targets[0].id;
    setActiveLink(currentId);
  };

  setInitialActiveLink();

  window.addEventListener('scroll', () => {
    if (isClickScrolling) return;
    if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 5) {
      const last = targets[targets.length - 1];
      const id = last?.getAttribute('id');
      if (id) setActiveLink(id);
    }
  }, { passive: true });
});
</script>
</Layout>
