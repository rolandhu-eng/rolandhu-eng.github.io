---
import katex from 'katex';
import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import { aeolusNav, getProject } from '../../../data/projects';

const project = getProject('aeolus');

const tocItems = [
  { id: "overview", label: "1.1 Overview" },
  { id: "systems", label: "1.2 Systems" },
  { id: "avionics", label: "1.3 Avionics" }
];
---

<ProjectLayout
  title={project.title}
  description={project.description}
  dateRange={project.dateRange}
  tags={project.tags}
  heroMedia={project.cover}
  isVideo={project.isVideo}
  toc={tocItems}
  subpages={aeolusNav}
  activePageId="overview"
  showHero={true}
  sidebarTitle="Aeolus Documentation"
  statusLabel='In Development'
  statusDot = {true}
>
  <section id="overview" class="scroll-mt-28">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-4">01. Overview</h2>
    <p class="leading-relaxed text-slate-600 dark:text-slate-300 font-light">
      Aeolus is a thrust-vane-stabilized electric ducted (EDF) fan rocket designed for controlled flight in a small space. Unlike the common solid rocket motors, an EDF can be throttled continuously, enabling controlled ascent, hover, and landing without the large field clearances that pyrotechnic motors require. This throttleability introduces a harder engineering problem: at hover, airspeed is zero, fins generate no restoring moment, and the vehicle is aerodynamically unstable. The only stabilization mechanism is active attitude control via four exhaust vanes in the EDF jet — which requires accurate real-time attitude estimation, a fast closed-loop controller, and a reliable telemetry link, all running on custom flight hardware small enough to fit a 70mm airframe. Every subsystem was designed and built from scratch: the sensor fusion pipeline, radio protocol, RPM governor, 6DOF simulation, and ground station.
    </p>
  </section>

  <hr class="border-slate-200 dark:border-slate-800" />

  <section id="systems" class="scroll-mt-28">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-4">02. Systems</h2>
    <p class="leading-relaxed text-slate-600 dark:text-slate-300 font-light">
      The Aeolus project explores active trajectory stabilization using an Electric Ducted Fan (EDF)
      combined with Thrust Vector Control (TVC) and aerodynamic fin actuation. Traditional model rockets
      rely purely on passive aerodynamic stability; Aeolus attempts to actively counteract wind shear and
      thrust imbalances in real-time.
    </p>
    <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300 font-light">
      lorem ipsuol deolar sait amet asdhoi because shown is <span set:html={katex.renderToString('\\mathcal{L}=T-V', { throwOnError: false })} /> ansd this it is trivial that <span set:html={katex.renderToString('\\frac{d}{dt}\\frac{\\partial \\mathcal{L}}{\\partial \\dot q} = \\frac{\\partial\\mathcal{L}}{\\partial q}', { throwOnError: false })} />
